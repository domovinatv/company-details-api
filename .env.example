# Firecrawl — one key, or several comma-separated for automatic rotation when
# a key runs out of credits (same pattern as klubovi.domovina.ai).
FIRECRAWL_API_KEYS=fc-xxxxxxxxxxxx,fc-yyyyyyyyyyyy
# Backward-compat single key (used only if FIRECRAWL_API_KEYS is unset):
# FIRECRAWL_API_KEY=fc-xxxxxxxxxxxx

# Throttle between Firecrawl requests, seconds (default 0.5).
FIRECRAWL_THROTTLE_S=0.5
